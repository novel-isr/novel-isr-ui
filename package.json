{
  "name": "@novel-isr/ui",
  "version": "0.1.0",
  "description": "novel-platform UI 组件库 —— Chakra v3 inspired API + 现代克制视觉 + 一等公民 dark mode",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/novel-isr/novel-isr-ui.git"
  },
  "homepage": "https://github.com/novel-isr/novel-isr-ui",
  "bugs": "https://github.com/novel-isr/novel-isr-ui/issues",
  "engines": {
    "node": ">=20.10.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css",
    "build:js": "vite build",
    "build:css": "sass src/styles/index.scss dist/styles.css --no-source-map --style=compressed",
    "dev": "concurrently 'pnpm run build:js -- --watch' 'pnpm run build:css --watch'",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist",
    "prepare": "pnpm run build"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "sass-embedded": "^1.79.0",
    "typescript": "^5.6.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.5"
  }
}
